// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  role      String     @default("ROLE_USER")
  nom       String
  prenom    String
  documents Document[]
  annonces  Annonce[]
  saes      Sae[]
}

model Sae {
  id                 Int        @id @default(autoincrement())
  titre              String
  description        String     @db.Text
  semestre           Int
  anneeUniversitaire String
  dateEcheance       DateTime
  documents          Document[]
  annonces           Annonce[]
  users              User[]
}

model Document {
  id            Int     @id @default(autoincrement())
  nom           String
  cheminFichier String
  type          String  // consigne, ressource, rendu
  saeId         Int
  userId        Int
  sae           Sae     @relation(fields: [saeId], references: [id])
  user          User    @relation(fields: [userId], references: [id])
}

model Annonce {
  id              Int      @id @default(autoincrement())
  titre           String
  contenu         String   @db.Text
  datePublication DateTime @default(now())
  saeId           Int
  userId          Int
  sae             Sae      @relation(fields: [saeId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}
