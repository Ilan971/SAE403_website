// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  password     String
  role         String     @default("ROLE_USER")
  nom          String
  prenom       String
  documents    Document[]
  annonces     Annonce[]
  saes         Sae[]
  notesRecues  Note[]     @relation("NotesRecues")
  notesDonnees Note[]     @relation("NotesDonnees")
}

model Sae {
  id                 Int        @id @default(autoincrement())
  titre              String
  description        String     @db.Text
  semestre           Int
  anneeUniversitaire String
  dateEcheance       DateTime
  isPublic           Boolean    @default(false)
  documents          Document[]
  annonces           Annonce[]
  users              User[]
  notes              Note[]
}

model Document {
  id            Int      @id @default(autoincrement())
  nom           String
  cheminFichier String
  type          String   // consigne, ressource, rendu
  dateDepot     DateTime @default(now())
  saeId         Int
  userId        Int
  sae           Sae      @relation(fields: [saeId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
}

model Annonce {
  id              Int      @id @default(autoincrement())
  titre           String
  contenu         String   @db.Text
  datePublication DateTime @default(now())
  saeId           Int
  userId          Int
  sae             Sae      @relation(fields: [saeId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model Note {
  id          Int      @id @default(autoincrement())
  valeur      Float
  commentaire String?  @db.Text
  dateNotation DateTime @default(now())
  saeId       Int
  etudiantId  Int
  profId      Int
  sae         Sae      @relation(fields: [saeId], references: [id])
  etudiant    User     @relation("NotesRecues", fields: [etudiantId], references: [id])
  prof        User     @relation("NotesDonnees", fields: [profId], references: [id])

  @@unique([saeId, etudiantId])
}
